# Sub2API / OpenAI-compatible config
SUB2API_API_KEY=YOUR_SUB2API_API_KEY_HERE
SUB2API_BASE_URL=https://api.yksa.uk/v1
SUB2API_MODEL=gpt-5.2

# Local or Render backend
HOST=0.0.0.0
PORT=8790

# For Render production set this after Vercel URL is known
# Example: https://your-vercel-project.vercel.app
ALLOWED_ORIGINS=*
